<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
    Scoped engine deploy manifest for salesforce-mock-data-gen.

    Use this manifest (NOT the generic package.xml) when deploying the engine
    into a customer demo project. Excludes:
      - Apex *Test classes (not required for demo deploys)
      - RFP_Analysis plugin and Launch_RFP_Analysis_Flow function (orphan
        capability, references a Flow not present in this repo, not part of
        mock data generation)

    Components: 25 (5 ApexClass + 5 Flow + 5 FlowDefinition + 5 GenAiFunction
    + 5 GenAiPlugin + 6 GenAiPromptTemplate). RFP_Analysis plugin and
    Launch_RFP_Analysis_Flow function are excluded; if those are restored
    upstream, this manifest must be updated explicitly.

    Maintained alongside the engine source — when generators are added or
    removed upstream, update this manifest in the same commit.

    First validation: deployment 0Afg7000003nkrBCAQ to SDGovSPIKE org
    (Candidate A subtree-split install, May 2026 spike).
-->

<Package xmlns="http://soap.sforce.com/2006/04/metadata">
    <types>
        <members>CaseGenerator</members>
        <members>ContactGenerator</members>
        <members>EmailCreatorFromAI</members>
        <members>KnowledgeArticleGenerator</members>
        <members>TaskEventGenerator</members>
        <name>ApexClass</name>
    </types>
    <types>
        <members>AI_Email_Generator</members>
